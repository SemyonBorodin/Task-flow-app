<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="001-create-users" author="s.borodin">
        <createTable tableName="users">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="varchar(255)"/>
            <column name="name" type="varchar(255)"/>
            <column name="avatar_url" type="varchar(1024)"/>
            <column name="email_verified" type="boolean" defaultValueBoolean="false"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="002-create-workspaces" author="s.borodin">
        <createTable tableName="workspaces">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="uuid"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="workspaces" baseColumnNames="owner_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_workspaces_owner"/>
    </changeSet>

    <changeSet id="003-create-workspace-members" author="s.borodin">
        <createTable tableName="workspace_members">
            <column name="workspace_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(50)"/>
        </createTable>
        <addPrimaryKey columnNames="workspace_id, user_id" tableName="workspace_members" constraintName="pk_workspace_members"/>
        <addForeignKeyConstraint baseTableName="workspace_members" baseColumnNames="workspace_id" referencedTableName="workspaces" referencedColumnNames="id" constraintName="fk_workspace_members_workspace"/>
        <addForeignKeyConstraint baseTableName="workspace_members" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_workspace_members_user"/>
    </changeSet>

    <changeSet id="004-create-projects" author="s.borodin">
        <createTable tableName="projects">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="workspace_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="created_by" type="uuid"/>
            <column name="archived" type="boolean" defaultValueBoolean="false"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="projects" baseColumnNames="workspace_id" referencedTableName="workspaces" referencedColumnNames="id" constraintName="fk_projects_workspace"/>
        <addForeignKeyConstraint baseTableName="projects" baseColumnNames="created_by" referencedTableName="users" referencedColumnNames="id" constraintName="fk_projects_created_by"/>
    </changeSet>

    <changeSet id="005-create-tasks" author="s.borodin">
        <createTable tableName="tasks">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
                <column name="details" type="varchar(255)">
                    <constraints nullable="false"/>
                </column>
                <column name="completed" type="boolean" defaultValueBoolean="false"/>
            <column name="status" type="varchar(50)"/>
            <column name="priority" type="varchar(20)"/>
            <column name="due_date" type="timestamp"/>
            <column name="created_by" type="uuid"/>
            <column name="assignee_id" type="uuid"/>
            <column name="parent_task_id" type="uuid"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="tasks" baseColumnNames="project_id" referencedTableName="projects" referencedColumnNames="id" constraintName="fk_tasks_project"/>
        <addForeignKeyConstraint baseTableName="tasks" baseColumnNames="created_by" referencedTableName="users" referencedColumnNames="id" constraintName="fk_tasks_created_by"/>
        <addForeignKeyConstraint baseTableName="tasks" baseColumnNames="assignee_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_tasks_assignee"/>
        <addForeignKeyConstraint baseTableName="tasks" baseColumnNames="parent_task_id" referencedTableName="tasks" referencedColumnNames="id" constraintName="fk_tasks_parent"/>
    </changeSet>

    <changeSet id="006-create-task-responsibles" author="s.borodin">
        <createTable tableName="task_responsibles">
            <column name="task_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="task_id, user_id" tableName="task_responsibles" constraintName="pk_task_responsibles"/>
        <addForeignKeyConstraint baseTableName="task_responsibles" baseColumnNames="task_id" referencedTableName="tasks" referencedColumnNames="id" constraintName="fk_task_responsibles_task"/>
        <addForeignKeyConstraint baseTableName="task_responsibles" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_task_responsibles_user"/>
    </changeSet>

    <changeSet id="007-create-comments" author="s.borodin">
        <createTable tableName="comments">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="task_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="uuid"/>
            <column name="content" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="comments" baseColumnNames="task_id" referencedTableName="tasks" referencedColumnNames="id" constraintName="fk_comments_task"/>
        <addForeignKeyConstraint baseTableName="comments" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_comments_user"/>
    </changeSet>

    <changeSet id="008-create-attachments" author="s.borodin">
        <createTable tableName="attachments">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="task_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="file_name" type="varchar(1024)"/>
            <column name="file_url" type="varchar(2048)"/>
            <column name="uploaded_by" type="uuid"/>
            <column name="uploaded_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="attachments" baseColumnNames="task_id" referencedTableName="tasks" referencedColumnNames="id" constraintName="fk_attachments_task"/>
        <addForeignKeyConstraint baseTableName="attachments" baseColumnNames="uploaded_by" referencedTableName="users" referencedColumnNames="id" constraintName="fk_attachments_user"/>
    </changeSet>

    <changeSet id="009-create-task-history" author="s.borodin">
        <createTable tableName="task_history">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="task_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="uuid"/>
            <column name="field" type="varchar(255)"/>
            <column name="old_value" type="text"/>
            <column name="new_value" type="text"/>
            <column name="changed_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_history" baseColumnNames="task_id" referencedTableName="tasks" referencedColumnNames="id" constraintName="fk_task_history_task"/>
        <addForeignKeyConstraint baseTableName="task_history" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_task_history_user"/>
    </changeSet>

    <changeSet id="010-create-notifications" author="s.borodin">
        <createTable tableName="notifications">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="varchar(100)"/>
            <column name="content" type="text"/>
            <column name="is_read" type="boolean" defaultValueBoolean="false"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="notifications" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_notifications_user"/>
    </changeSet>

</databaseChangeLog>
